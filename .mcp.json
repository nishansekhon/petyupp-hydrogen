{
  "mcpServers": {
    "shopify": {
      "command": "npx",
      "args": [
        "-y",
        "shopify-mcp",
        "--clientId",
        "${SHOPIFY_CLIENT_ID}",
        "--clientSecret",
        "${SHOPIFY_CLIENT_SECRET}",
        "--domain",
        "shopyupp.myshopify.com"
      ]
    }
  }
}
